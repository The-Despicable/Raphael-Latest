# ============================================================
# Raphael 2.0 — Layer 5 Shared Environment Configuration
# ============================================================

# --- Tor Proxy ---
TOR_PROXY=socks5h://tor-proxy:9050
TOR_CONTROL=tor-proxy:9051
TOR_PASSWORD=changeme

# --- API Security ---
API_KEY=raphael-layer5-dev-key-2026
JWT_SECRET=raphael-jwt-secret-change-in-production

# --- MHDDoS ---
MHDDOS_THREADS=1000
MHDDOS_DEFAULT_METHOD=HTTP

# --- Phishing (GoPhish) ---
GOPHISH_API_HOST=https://127.0.0.1
GOPHISH_API_PORT=3333
GOPHISH_API_KEY=change-me-gophish-api-key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@example.com

# --- C2 Server ---
C2_LISTENER_PORT=443
PUPPY_LISTENER=0.0.0.0:443
WINRM_USER=Administrator
WINRM_PASS=changeme
WINRM_PORT=5985

# --- Recon Pipeline ---
SHODAN_API_KEY=
SPIDERFOOT_API_KEY=
SUBFINDER_CONFIG=

# --- BloodHound / Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=raphael-dev

# --- Proxy Strategy ---
PROXY_STRATEGY=auto
PROTONVPN_SERVICE_CHECK=1
ACADEMIC_JUMPS=
SSH_KEY_PATH=
CHAIN_ORDER=academic->protonvpn->target

# --- Anti-Forensics ---
AUTO_CLEANUP=true
DEFAULT_PLATFORM=linux
CLEANUP_LEVEL=standard

# --- Behavioral Mimicry ---
MIMICRY_TZ=Asia/Kolkata
MIMICRY_VELOCITY=medium
MIMICRY_BUSINESS_HOURS_START=0900
MIMICRY_BUSINESS_HOURS_END=1700
MIMICRY_DAYS=weekdays

# --- CAI Service ---
# WARNING: Set your actual API key via environment variable at container runtime
# Do NOT hardcode keys in this file. Rotate immediately if this was ever committed.
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_MODEL=blackgrg26/WORMGPT-13:latest
# Fill in your API keys below
NVIDIA_API_KEY=
OPENAI_API_KEY=
