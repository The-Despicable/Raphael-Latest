# ============================================================
# Raphael 2.0 — Environment Configuration
# ============================================================
# Copy to .env and fill in your keys. NEVER commit .env.
# cp .env.example .env

# --- API Keys (at least one required) ---
# NVIDIA API (free tier): build.nvidia.com → API Keys
NVIDIA_API_KEY=
# OpenRouter / OpenAI-compatible fallback
OPENAI_API_KEY=
# OmniRoute local proxy (free fallback provider)
OMNIROUTE_BASE=http://localhost:20128/v1
OMNIROUTE_API_KEY=sk-omniroute-local

# --- Cost Control ---
MAX_SPEND_TOKENS=1000000
RAPHAEL_COST_CONTROL=1

# --- Tor Proxy ---
TOR_PROXY=socks5h://tor-proxy:9050
TOR_CONTROL=tor-proxy:9051
TOR_PASSWORD=changeme

# --- API Security ---
API_KEY=raphael-layer5-dev-key-2026
JWT_SECRET=raphael-jwt-secret-change-in-production

# --- MHDDoS ---
MHDDOS_THREADS=1000
MHDDOS_DEFAULT_METHOD=HTTP

# --- Phishing (GoPhish) ---
GOPHISH_API_HOST=https://127.0.0.1
GOPHISH_API_PORT=3333
GOPHISH_API_KEY=change-me-gophish-api-key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_PASS=
FROM_EMAIL=noreply@example.com

# --- C2 Server ---
C2_LISTENER_PORT=443
PUPPY_LISTENER=0.0.0.0:443
WINRM_USER=Administrator
WINRM_PASS=changeme
WINRM_PORT=5985

# --- Recon Pipeline ---
SHODAN_API_KEY=
SPIDERFOOT_API_KEY=
SUBFINDER_CONFIG=

# --- BloodHound / Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASS=raphael-dev

# --- Proxy Strategy ---
PROXY_STRATEGY=auto
PROTONVPN_SERVICE_CHECK=1
ACADEMIC_JUMPS=
SSH_KEY_PATH=
CHAIN_ORDER=academic->protonvpn->target

# --- Anti-Forensics ---
AUTO_CLEANUP=true
DEFAULT_PLATFORM=linux
CLEANUP_LEVEL=standard

# --- Behavioral Mimicry ---
MIMICRY_TZ=Asia/Kolkata
MIMICRY_VELOCITY=medium
MIMICRY_BUSINESS_HOURS_START=0900
MIMICRY_BUSINESS_HOURS_END=1700
MIMICRY_DAYS=weekdays

# --- Ollama (local proxy for worm models) ---
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_MODEL=blackgrg26/WORMGPT-13:latest
